<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OmniVoiceApi.Maui.MainPage"
             Title="OmniVoiceApi">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label Text="OmniVoiceApi" Style="{StaticResource Headline}" />
            <Label
                Text="API base URL (Android emulator: http://10.0.2.2:8765)"
                FontSize="12"
                TextColor="{StaticResource Gray500}" />

            <Entry x:Name="BaseUrlEntry"
                   Text="http://127.0.0.1:8765"
                   Placeholder="http://127.0.0.1:8765"
                   Keyboard="Url" />

            <Entry x:Name="LanguageEntry"
                   Text="French"
                   Placeholder="Language" />

            <Editor x:Name="TextEditor"
                    Text="Bonjour."
                    Placeholder="Text to synthesize"
                    HeightRequest="120"
                    AutoSize="TextChanges" />

            <Button x:Name="SynthesizeBtn"
                    Text="Synthétiser"
                    Clicked="OnSynthesizeClicked"
                    HorizontalOptions="Fill" />

            <Button x:Name="PlayBtn"
                    Text="Lire le dernier résultat"
                    Clicked="OnPlayClicked"
                    IsEnabled="False"
                    HorizontalOptions="Fill" />

            <Label x:Name="StatusLabel"
                   Text=""
                   FontSize="13" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
