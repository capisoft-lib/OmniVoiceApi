# OmniVoiceApi — copy to `.env` and adjust (used by docker-compose / local tooling)

# Hugging Face model id or local checkpoint
OMNIVOICE_MODEL=k2-fsa/OmniVoice

# Directory for voice library (uploads + basename lookup for cloning)
OMNIVOICE_VOICES_DIR=/data/voices

# cuda | mps | cpu (empty = auto)
OMNIVOICE_DEVICE=cuda

# Optional: mirror for Hugging Face downloads
# HF_ENDPOINT=https://hf-mirror.com
